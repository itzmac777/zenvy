# Public app URL used by the browser, PayStation callbacks, CORS, and secure cookies.
PUBLIC_APP_URL=https://zenvy.example.com

# Caddy automatic HTTPS site address. Use the bare domain for production.
# Example: zenvy.example.com
CADDY_SITE_ADDRESS=zenvy.example.com
ACME_EMAIL=admin@example.com

# Optional only when using docker-compose.existing-proxy.yml on a VPS where 80/443 are already occupied.
CLIENT_BIND=127.0.0.1:3200
SERVER_BIND=127.0.0.1:4200

# Client-visible settings.
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
NEXT_PUBLIC_MANAGER_UI_VERSION=simple
NEXT_PUBLIC_MANAGER_SUPPORT_PHONE=+8801000000000
NEXT_PUBLIC_MANAGER_SUPPORT_WHATSAPP=8801000000000

# Server secrets and providers.
OTP_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=zenvy_manager_session
SESSION_DAYS=30
MANAGER_INVITES_REQUIRED=false

IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_FIELD_FOLDER=/zenvy/fields

PAYSTATION_BASE_URL=https://api.paystation.com.bd
PAYSTATION_STORE_ID=2693-1775830347
PAYSTATION_PASSWORD=
PAYSTATION_MOCK=false
